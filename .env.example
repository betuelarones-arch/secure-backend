# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/secure_db?schema=public"

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
JWT_PARTIAL_EXPIRES_IN=5m

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (Gmail) - Configuración para MFA por Email
EMAIL_USER=betuel.arones@tecsup.edu.pe
EMAIL_APP_PASSWORD=tu_app_password_de_16_caracteres

# MFA Default Email - Todos los códigos MFA se envían a este correo
MFA_DEFAULT_EMAIL=betuel.arones@tecsup.edu.pe
